{
	"name": "gofront",
	"version": "0.0.7",
	"author": "Luuk van Venrooij",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/seriva/gofront.git"
	},
	"bugs": {
		"url": "https://github.com/seriva/gofront/issues"
	},
	"homepage": "https://github.com/seriva/gofront#readme",
	"description": "A Go-inspired language that transpiles to JavaScript",
	"keywords": [
		"go",
		"compiler",
		"transpiler",
		"javascript",
		"frontend",
		"type-safe"
	],
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"files": [
		"src/"
	],
	"bin": {
		"gofront": "./src/index.js"
	},
	"scripts": {
		"build:simple": "node src/index.js example/simple/src -o example/simple/app.js",
		"build:reactive": "node src/index.js example/reactive/src -o example/reactive/app.js",
		"build:gom": "node src/index.js example/gom/src -o example/gom/app.js",
		"test": "npm run test:unit && npm run test:e2e",
		"test:unit": "node test/unit/run.js",
		"test:e2e": "playwright test",
		"format": "biome format --write .",
		"check": "biome check .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@playwright/test": "^1.59.1",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"serve": "^14.2.6"
	}
}
