{
	"name": "gofront",
	"version": "1.0.0",
	"author": "Luuk van Venrooij",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/seriva/gofront.git"
	},
	"bugs": {
		"url": "https://github.com/seriva/gofront/issues"
	},
	"homepage": "https://github.com/seriva/gofront#readme",
	"description": "A Go-inspired language that transpiles to JavaScript",
	"keywords": [
		"go",
		"compiler",
		"transpiler",
		"javascript",
		"frontend",
		"type-safe"
	],
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"files": [
		"src/"
	],
	"bin": {
		"gofront": "./src/index.js"
	},
	"scripts": {
		"build:simple": "node src/index.js example/simple/src -o example/simple/app.js",
		"build:reactive": "node src/index.js example/reactive/src -o example/reactive/app.js",
		"build:gom": "node src/index.js example/gom/src -o example/gom/app.js",
		"build:templ": "node src/index.js example/templ/src -o example/templ/app.js",
		"build:all": "npm run build:simple && npm run build:reactive && npm run build:gom && npm run build:templ",
		"test:all": "npm run test:unit && npm run test:e2e",
		"test:unit": "node test/unit/run.js",
		"test:coverage": "c8 --include='src/**' --reporter=text --reporter=lcov node test/unit/run.js",
		"test:e2e": "npm run build:all && playwright test",
		"format": "biome format --write .",
		"check": "biome check . && sentrux check && sentrux gate && node src/index.js example/simple/src --check && node src/index.js example/reactive/src --check && node src/index.js example/gom/src --check && node src/index.js example/templ/src --check",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@playwright/test": "^1.59.1",
		"c8": "^11.0.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"serve": "^14.2.6"
	}
}
